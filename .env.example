# Database configuration
# DATABASE_URL=./data/paperless-ngx-dedupe.db

# Paperless-NGX connection (required)
PAPERLESS_URL=http://localhost:8000

# Authentication: provide either API token OR username+password
PAPERLESS_API_TOKEN=your-api-token-here
# PAPERLESS_USERNAME=admin
# PAPERLESS_PASSWORD=password


# EVERYTHING BELOW THIS LINE IS OPTIONAL AND HAS REASONABLE DEFAULTS. UNCOMMENT AND MODIFY AS NEEDED

# Server configuration
# PORT=3000
# LOG_LEVEL=info

# --- AI Processing (optional, disabled by default) ---

# Enable AI-powered document classification and metadata extraction
# AI_ENABLED=false

# OpenAI API key (required when AI_ENABLED=true)
# AI_OPENAI_API_KEY=sk-...

# --- Document Q&A / RAG (optional, disabled by default) ---

# Enable natural language question answering across your documents using RAG.
# Requires AI_OPENAI_API_KEY for embeddings and answer generation.
# RAG_ENABLED=false

# Docker: user/group ID for file ownership (default: 1000)
# Find your IDs with: id $USER
# PUID=1000
# PGID=1000

# CORS: empty = same-origin only, '*' = all origins, or a specific origin URL
# CORS_ALLOW_ORIGIN=

# Auto-run migrations on startup
# AUTO_MIGRATE=true

# --- Grafana Faro Frontend Observability (optional, disabled by default) ---
#
# Captures frontend errors, Web Vitals, console logs, distributed traces,
# and custom events/measurements. Sends data to Grafana Cloud via the
# Faro collector endpoint.

# Enable Grafana Faro Web SDK instrumentation
# FARO_ENABLED=false

# Faro collector URL (required when FARO_ENABLED=true)
# Get this from Grafana Cloud → Observability → Frontend → Create new
# FARO_COLLECTOR_URL=https://faro-collector-prod-xx-yyyy-0.grafana.net/collect/your-key

# --- Pyroscope Continuous Profiling (optional, disabled by default) ---
#
# Captures wall-time and heap profiles from the Node.js runtime.
# Sends to Grafana Cloud Pyroscope or a self-hosted Pyroscope server.
# Use operation labels (sync, analysis, ai_batch, worker) to filter
# flame graphs by code path.

# Enable continuous profiling
# PYROSCOPE_ENABLED=false

# Pyroscope server endpoint (required when PYROSCOPE_ENABLED=true)
# For Grafana Cloud: https://profiles-prod-xxx.grafana.net
# PYROSCOPE_SERVER_ADDRESS=

# Grafana Cloud authentication (required for Grafana Cloud Pyroscope)
# PYROSCOPE_BASIC_AUTH_USER=<instance-id>
# PYROSCOPE_BASIC_AUTH_PASSWORD=<api-key>

# --- OpenTelemetry Observability (all optional, disabled by default) ---
#
# Enabling OTEL_ENABLED or OTEL_PROMETHEUS_ENABLED automatically exposes the
# app's own metrics (sync runs, analysis, jobs, AI usage, etc.) with zero
# additional config.
#
# Paperless-NGX system metrics (document counts, storage, tags, etc.) are a
# separate opt-in — see PAPERLESS_METRICS_ENABLED below.

# Full observability — enables traces, OTLP metrics, log correlation, and auto-instrumentation.
# Pushes metrics and traces to an OTLP collector.
# OTEL_ENABLED=false

# Prometheus scrape endpoint — serves app metrics at GET /api/v1/metrics.
# Can be used standalone OR alongside OTEL_ENABLED=true.
# No OTLP collector required — Prometheus scrapes the endpoint directly.
# OTEL_PROMETHEUS_ENABLED=false

# Logical name for this service in your observability backend
# OTEL_SERVICE_NAME=paperless-ngx-dedupe

# Logical namespace grouping frontend and backend in Grafana Cloud App Observability
# OTEL_SERVICE_NAMESPACE=paperless-dedupe

# --- Paperless-NGX System Metrics (optional, separately opt-in) ---
# Collect system-level metrics from your Paperless-NGX instance (status, storage,
# document counts, tags, etc.). Replaces running a separate prometheus-paperless-exporter
# container. Metrics are available via whichever pipeline is active (OTLP and/or Prometheus).
# Duplicates metrics from https://github.com/hansmi/prometheus-paperless-exporter/
#
# Requires OTEL_ENABLED=true or OTEL_PROMETHEUS_ENABLED=true.
# Opt-in because collectors poll the Paperless API every export interval (~60s),
# which adds load to your Paperless instance.
# PAPERLESS_METRICS_ENABLED=false

# Comma-separated list of collectors to enable. If empty, all collectors are enabled.
# Available: status, statistics, document, tag, correspondent, document_type,
#            storage_path, task, group, user, remote_version
# PAPERLESS_METRICS_COLLECTORS=

# --- OTLP Exporter ---

# Base URL of the OpenTelemetry Collector (HTTP/protobuf)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Override per-signal endpoints if your collector uses different paths
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:4318/v1/logs

# Transport protocol: grpc, http/protobuf, or http/json
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Custom headers sent with every export request (e.g. for auth tokens)
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <token>

# Enable gzip compression for OTLP exports (recommended for Grafana Cloud)
# OTEL_EXPORTER_OTLP_COMPRESSION=gzip

# --- Signal Exporters ---
# Exporter for each signal: otlp, console, or none
# OTEL_TRACES_EXPORTER=otlp
# OTEL_METRICS_EXPORTER=otlp
# Log records are sent to the OTEL Logs SDK by default when OTEL_ENABLED=true.
# Set to "none" to disable OTLP log export (useful when collecting stdout with Promtail/Alloy).
# OTEL_LOGS_EXPORTER=otlp

# --- Trace Sampling ---
# Sampling strategy: always_on, always_off, traceidratio, parentbased_traceidratio
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# Sampling ratio for ratio-based samplers (0.0 = none, 1.0 = all)
# OTEL_TRACES_SAMPLER_ARG=1.0

# --- Resource Attributes ---
# Environment and instance ID are auto-detected from NODE_ENV and HOSTNAME.
# Override explicitly if needed:
# OTEL_DEPLOYMENT_ENVIRONMENT=production
# OTEL_SERVICE_INSTANCE_ID=my-instance-1
#
# Additional key=value resource attributes attached to all telemetry
# OTEL_RESOURCE_ATTRIBUTES=service.namespace=paperless

# Opt into stable database semantic conventions (recommended)
# OTEL_SEMCONV_STABILITY_OPT_IN=database

# --- Propagation ---
# Context propagation formats: tracecontext, baggage, b3, b3multi, jaeger
# OTEL_PROPAGATORS=tracecontext,baggage

# --- Metric Export Interval ---
# How often metrics are exported in ms (default 60000)
# OTEL_METRIC_EXPORT_INTERVAL=60000

# SDK internal log level for troubleshooting: none, error, warn, info, debug, verbose
# OTEL_LOG_LEVEL=warn


